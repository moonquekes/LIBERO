<mujoco model="suction_hand">
    <!--
        Suction cup gripper for LIBERO / robosuite.
        Design:
          - A short cylindrical wrist adaptor.
          - A disc-shaped suction pad at the tip (flat cylinder).
          - A thin rubber rim ring modeled as a torus-like capsule ring.
          - No open/close joints: DOF=0, but we use an equality weld
            constraint (activated externally by SuctionGripper.format_action)
            to simulate vacuum adhesion.
        Control signal:  action ∈ [-1, 1]
            > 0  → suction ON  (weld constraint enabled)
            ≤ 0  → suction OFF (weld constraint disabled)
    -->
    <actuator>
        <!-- dummy actuator so robosuite action-space dimension = 1 -->
        <general name="suction_valve" joint="suction_dummy_joint"
                 ctrllimited="true" ctrlrange="-1 1"
                 gainprm="100 0 0" biasprm="0 -100 0" biastype="affine"/>
    </actuator>

    <worldbody>
        <body name="right_gripper" pos="0 0 0" quat="0.707107 0 0 -0.707107">

            <!-- Force-torque frame -->
            <site name="ft_frame" pos="0 0 0" size="0.01 0.01 0.01"
                  rgba="1 0 0 1" type="sphere" group="1"/>
            <inertial pos="0 0 0.06" mass="0.25"
                      diaginertia="0.005 0.005 0.003"/>

            <!-- Wrist adaptor: thin cylinder -->
            <geom name="wrist_visual" type="cylinder" size="0.018 0.020"
                  pos="0 0 0.020" contype="0" conaffinity="0" group="1"
                  rgba="0.85 0.85 0.85 1"/>
            <geom name="wrist_collision" type="cylinder" size="0.018 0.020"
                  pos="0 0 0.020" contype="1" conaffinity="1"
                  friction="0.5 0.005 0.0001" group="0"/>

            <!-- Suction cup body -->
            <body name="suction_cup_body" pos="0 0 0.05">
                <inertial pos="0 0 0.015" mass="0.08"
                          diaginertia="0.001 0.001 0.001"/>

                <!-- Dummy sliding joint: needed so the actuator has a joint to bind to.
                     Range is locked tight — cup cannot move. -->
                <joint name="suction_dummy_joint" type="slide" axis="0 0 1"
                       limited="true" range="-0.0001 0.0001"
                       damping="1000" armature="0.5" frictionloss="0.5"/>

                <!-- Outer rim ring (visual, dark rubber look) -->
                <geom name="rim_visual" type="cylinder" size="0.022 0.003"
                      pos="0 0 0.003" contype="0" conaffinity="0" group="1"
                      rgba="0.15 0.15 0.15 1"/>

                <!-- Inner pad (visual, lighter) -->
                <geom name="pad_visual" type="cylinder" size="0.015 0.002"
                      pos="0 0 0.003" contype="0" conaffinity="0" group="1"
                      rgba="0.35 0.35 0.35 1"/>

                <!-- Collision pad: high-friction flat disc for contact detection -->
                <geom name="suction_pad_collision" type="cylinder"
                      size="0.020 0.002" pos="0 0 0.005"
                      contype="1" conaffinity="1"
                      friction="3 0.1 0.01" condim="6"
                      solref="0.01 0.5" solimp="0.99 0.999 0.001"
                      group="0" rgba="0.2 0.2 0.2 1"/>

                <!-- EEF child body: grip site lives here -->
                <body name="eef" pos="0 0 0.01" quat="1 0 0 0">
                    <site name="grip_site" pos="0 0 0"
                          size="0.01 0.01 0.01" rgba="1 0 0 0.5"
                          type="sphere" group="1"/>
                    <!-- Suction on/off indicator: RED=off, GREEN=on; alpha=0 default so cameras never see it -->
                    <site name="suction_indicator" pos="0 0 0"
                          size="0.022 0.003" rgba="1 0 0 0"
                          type="cylinder" group="1"/>
                    <site name="suction_site" pos="0 0 0"
                          size="0.020 0.001" rgba="0 0.8 1 0.4"
                          type="cylinder" group="1"/>
                    <site name="ee_x" pos="0.1 0 0" size="0.005 .1"
                          quat="0.707105 0 0.707108 0" rgba="1 0 0 0"
                          type="cylinder" group="1"/>
                    <site name="ee_y" pos="0 0.1 0" size="0.005 .1"
                          quat="0.707105 0.707108 0 0" rgba="0 1 0 0"
                          type="cylinder" group="1"/>
                    <site name="ee_z" pos="0 0 0.1" size="0.005 .1"
                          quat="1 0 0 0" rgba="0 0 1 0"
                          type="cylinder" group="1"/>
                    <site name="grip_site_cylinder" pos="0 0 0"
                          size="0.005 10" rgba="0 1 0 0"
                          type="cylinder" group="1"/>
                </body>
            </body>
        </body>
    </worldbody>

    <sensor>
        <force  name="force_ee"  site="ft_frame"/>
        <torque name="torque_ee" site="ft_frame"/>
    </sensor>
</mujoco>
